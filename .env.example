# ══════════════════════════════════════════════════════
#  VisualVault Brand Kit Server — Variables d'environnement
# ══════════════════════════════════════════════════════

# ── Shopify ────────────────────────────────────────────
# Admin → Settings → Notifications → Webhooks → Signing secret
SHOPIFY_WEBHOOK_SECRET=shpss_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenAI ─────────────────────────────────────────────
# https://platform.openai.com/api-keys
# Modèles utilisés : gpt-4o (logo + textes) · dall-e-3 (hero image)
# Coût estimé par commande : ~$0.08-0.12 (logo + textes + image)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Canva Connect API ──────────────────────────────────
# https://www.canva.com/developers/
# Scopes nécessaires :
#   asset:read  asset:write
#   design:content:read  design:content:write
#   design:meta:read
#   folder:read  folder:write
#   profile:read
CANVA_ACCESS_TOKEN=your_canva_oauth_access_token

# IDs des 5 templates universels dans ton compte Canva
# (ouvrir le design → copier l'ID depuis l'URL)
# Ces templates ont des champs de données : "Brand Name", "Tagline", "Logo"
CANVA_TPL_LOGO=DAxxxxxxxxxxxxxx
CANVA_TPL_INSTAGRAM=DAxxxxxxxxxxxxxx
CANVA_TPL_STORY=DAxxxxxxxxxxxxxx
CANVA_TPL_BUSINESS_CARD=DAxxxxxxxxxxxxxx
CANVA_TPL_EMAIL_HEADER=DAxxxxxxxxxxxxxx

# ── Resend (email) ─────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Domaine vérifié dans Resend (ex: kits@visualvault.com)
FROM_EMAIL=kits@visualvault.com

# ── Serveur ────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# En production : NODE_ENV=production
